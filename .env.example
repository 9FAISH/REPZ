# Build-time only — copy to .env (gitignored). NEVER shipped to the client.
# Get a key: subscribe (free "Basic" plan, no card) to
# "ExerciseDB with videos and images by AscendAPI" on rapidapi.com,
# then copy your X-RapidAPI-Key here.
RAPIDAPI_KEY=

# Optional overrides (defaults shown) — swapping to a paid plan is just
# a different key/host here; the app itself never changes.
# EXDB_HOST=edb-with-videos-and-images-by-ascendapi.p.rapidapi.com
# EXDB_REQS_PER_HOUR=800
# EXDB_DETAIL_CAP=1000
# EXDB_PAGE_LIMIT=25
